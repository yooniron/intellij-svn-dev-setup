<configuration name="${PROJECT_NAME}"
               type="#com.intellij.j2ee.web.tomcat.TomcatRunConfigurationFactory"
               factoryName="Local"
               ALTERNATIVE_JRE_ENABLED="false">

    <option name="UPDATING_POLICY" value="restart-server"/>

    <deployment>
        <artifact name="${PROJECT_NAME}:Web exploded">
            <settings>
                <option name="CONTEXT_PATH" value="/"/>
            </settings>
        </artifact>
    </deployment>

    <server-settings>
        <option name="COMMON_VM_ARGUMENTS" value="-Dfile.encoding=UTF-8"/>
    </server-settings>

    <option name="HTTP_PORT" value="${SERVER_PORT}"/>
    <option name="TOMCAT_LOCATION" value="${TOMCAT_HOME}"/>

    <predefined_log_file enabled="true" id="Tomcat"/>

    <RunnerSettings RunnerId="Debug">
        <option name="DEBUG_PORT" value="56789"/>
    </RunnerSettings>

    <port value="${SERVER_PORT}"/>

    <method v="2">
        <option name="Make" enabled="true"/>
        <option name="BuildArtifacts" enabled="true">
            <artifact name="${PROJECT_NAME}:Web exploded"/>
        </option>
    </method>

</configuration>